{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "The unique GUID identifier for the settings"
        },
        "currentWeekId": {
            "type": "string",
            "description": "The current week of the NFL season"
        }
    },
    "required": [
        "id",
        "currentWeekId"
    ],
    "$example": {
        "id": "123e4567-e89b-12d3-a456-426614174000",
        "currentWeekId": "2026_01"
    }
}