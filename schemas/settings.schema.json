{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "The unique identifier for the settings (e.g. 'currentWeek')"
        },
        "currentWeekId": {
            "type": "string",
            "description": "The current week of the NFL season"
        }
    },
    "required": [
        "id",
        "currentWeekId"
    ],
    "$example": {
        "id": "currentWeek",
        "currentWeekId": "2026_01"
    }
}